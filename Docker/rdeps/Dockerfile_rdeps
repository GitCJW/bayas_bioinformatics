    'shinyjs'='2.1.0', 'shinyWidgets'='0.8.7', 'shinyTree'='0.3.1', \
    'shinycssloaders'='1.1.0', 'shinyalert'='3.1.0', 'shinyFeedback'='0.4.0', \
    'shinybusy'='0.3.3', 'bslib'='0.9.0', 'DT'='0.33', \
    'futile.logger'='1.4.3', 'future'='1.34.0', 'promises'='1.3.2', \
    'stringr'='1.5.1', 'dplyr'='1.1.4', 'tidyr'='1.3.1', \
    'bayesplot'='1.11.1', 'ggplot2'='3.5.1', 'LaplacesDemon'='16.1.6', \
