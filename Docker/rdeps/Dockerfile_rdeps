  ); \
  for (p in names(pkgs)) remotes::install_version(p, version=pkgs[[p]], upgrade='never', dependencies=TRUE); \"

RUN R -e "install.packages('HDInterval'); library('HDInterval')"
RUN R -e "install.packages('VGAM'); library('VGAM')"
