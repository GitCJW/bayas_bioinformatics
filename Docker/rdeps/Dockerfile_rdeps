FROM drcjw/bayas_core:1.0.0

LABEL org.opencontainers.image.authors="chrstoph.waterkamp@uni-due.de"

RUN R -q -e "install.packages('remotes', repos='https://cloud.r-project.org')"
RUN R -q -e " \
  options(repos = c(CRAN='https://cloud.r-project.org')); \
  pkgs <- c( \
    'nloptr'='2.1.1', 'lme4'='1.1-36', 'BH'='1.87.0-1', \
    'rstan'='2.32.6', 'rstanarm'='2.32.1', 'brms'='2.22.0', \
